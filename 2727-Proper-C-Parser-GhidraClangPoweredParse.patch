+                "Are you sure you want to delete profile " + item.getName(), "Delete",
+                OptionDialog.QUESTION_MESSAGE) == OptionDialog.OPTION_ONE)
+            {
+                item.file.delete();
+                itemList.remove(item);
+                comboModel.removeElement(item);
+            }
+        }
+    }

@@ -0,0 +1,41 @@
+<?xml version="1.0" encoding="UTF-8"?>
+<!--
+    Fairchild F8 / Mostek MK3870 Processor Specification
+
+    Register Model:
+    - A:     8-bit accumulator
+    - W:     8-bit status register (flags: S Z C O I)
+    - ISAR:  6-bit Indirect Scratchpad Address Register
+    - R0-R63: 64-byte scratchpad RAM
+    - PC0:   16-bit program counter
+    - PC1:   16-bit stack register (single level)
+    - DC0:   16-bit data counter
+    - DC1:   16-bit backup data counter
+
+    Special scratchpad aliases:
+    - J (R9):   Status backup
+    - HU (R10): DC0 high backup
+    - HL (R11): DC0 low backup
+    - KU (R12): PC1 high backup
+    - KL (R13): PC1 low backup
+    - QU (R14): PC0/DC0 high backup
+    - QL (R15): PC0/DC0 low backup
+-->
+<processor_spec>
+
+    <programcounter register="PC0"/>
+
+    <volatile outputop="OUT" inputop="IN">
+        <range space="io" first="0x0" last="0xFF"/>
+    </volatile>
+
+    <default_symbols>
+        <!-- Reset vector - execution begins at address 0 -->
+        <symbol name="RESET" address="ram:0x0000" entry="true"/>
+
+        <!-- I/O port names (3850 CPU ports) -->
+        <symbol name="PORT0" address="io:0x00"/>
+        <symbol name="PORT1" address="io:0x01"/>
+    </default_symbols>
+
+</processor_spec>
diff --git a/Ghidra/Processors/F8/data/languages/F8.slaspec b/Ghidra/Processors/F8/data/languages/F8.slaspec
new file mode 100644
index 0000000000..10f6459d76
--- /dev/null
+++ b/Ghidra/Processors/F8/data/languages/F8.slaspec
@@ -0,0 +1,1104 @@
+# Fairchild F8 / Mostek MK3870 SLEIGH Processor Specification
+# Covers all F8-family CPUs: F3850, F3870, MK3870, MK3872, MK3873, MK3875, MK3876
+# Based on F8 Guide to Programming and MK3870 datasheet
+
+define endian=big;
+define alignment=1;
+
+define space ram type=ram_space size=2 default;
+define space io type=ram_space size=1;
+define space register type=register_space size=1;
+
+# ============================================================================
+# Register Definitions
+# ============================================================================
+
+# Main registers
+define register offset=0x00 size=1 [ A W IS ];
+define register offset=0x10 size=2 [ PC0 PC1 DC0 DC1 ];
+
+# Scratchpad registers (64 bytes)
+define register offset=0x40 size=1 [
+    R0  R1  R2  R3  R4  R5  R6  R7
+    R8  R9  R10 R11 R12 R13 R14 R15
+    R16 R17 R18 R19 R20 R21 R22 R23
+    R24 R25 R26 R27 R28 R29 R30 R31
+    R32 R33 R34 R35 R36 R37 R38 R39
+    R40 R41 R42 R43 R44 R45 R46 R47
+    R48 R49 R50 R51 R52 R53 R54 R55
+    R56 R57 R58 R59 R60 R61 R62 R63
+];
+
+# Linkage register pairs - 16-bit overlays on scratchpad registers
+# These overlay R10:R11, R12:R13, R14:R15 at size=2 (no conflict with size=1)
+# The 8-bit aliases (J=R9, KU=R12, KL=R13, etc.) are NOT defined as
+# separate registers because SLEIGH forbids duplicate (offset,size) pairs.
+# Instead, instructions use R9-R15 directly for 8-bit access.
+# F8 Guide Table 6-7: J=r9, HU=r10, HL=r11, KU=r12, KL=r13, QU=r14, QL=r15
+# F3850 Datasheet Table 4: same mapping
+define register offset=0x4A size=2 [ H ];        # = R10:R11 (DC0 backup)
+define register offset=0x4C size=2 [ K ];        # = R12:R13 (PC1 backup)
+define register offset=0x4E size=2 [ Q ];        # = R14:R15 (PC0 backup)
+
+# ============================================================================
+# Token Definitions
+# ============================================================================
+
+define token opcode (8)
+    op8     = (0,7)
+    op4hi   = (4,7)
+    op4lo   = (0,3)
+    op3lo   = (0,2)
+    r4      = (0,3)
+    port4   = (0,3)
+    imm4    = (0,3)
+;
+
+define token byte1 (8)
+    imm8    = (0,7)
+    simm8   = (0,7) signed
+    port8   = (0,7)
+;
+
+define token word1 (16)
+    addr16  = (0,15)
+;
+
+# ============================================================================
+# Attach Variables
+# ============================================================================
+
+# Attach r4 to direct scratchpad registers (0-15)
+attach variables [ r4 ] [
+    R0  R1  R2  R3  R4  R5  R6  R7
+    R8  R9  R10 R11 R12 R13 R14 R15
+];
+
+# ============================================================================
+# Display Subtables for Register Names
+# These create proper operand display in the disassembly
+# ============================================================================
+
+# Accumulator display
+acc: "A" is epsilon { }
+
+# Indirect addressing modes (S=IS, I=IS++, D=IS--)
+iS: "S" is epsilon { }
+iI: "I" is epsilon { }
+iD: "D" is epsilon { }
+
+# Special register display names
+sKU: "KU" is epsilon { }
+sKL: "KL" is epsilon { }
+sQU: "QU" is epsilon { }
+sQL: "QL" is epsilon { }
+sK: "K" is epsilon { }
+sP: "P" is epsilon { }
+sIS: "IS" is epsilon { }
+sP0: "P0" is epsilon { }
+sQ: "Q" is epsilon { }
+sDC: "DC" is epsilon { }
+sH: "H" is epsilon { }
+sW: "W" is epsilon { }
+sJ: "J" is epsilon { }
+
+# Shift amounts
+sh1: "1" is epsilon { }
+sh4: "4" is epsilon { }
+
+# Unused register slot (r=15)
+r15: "15" is epsilon { }
+
+# ============================================================================
+# Macros for Status Flags
+# W register bits: bit 3=O, bit 2=Z, bit 1=C, bit 0=S, bit 4=ICB
+# ============================================================================
+
+macro setZS(result) {
+    W = (W & 0xFA) | (((result == 0) * 4) | ((result s>= 0) * 1));
+}
+
+macro clearOC() {
+    W = W & 0xF5;
+}
+
+macro setAddFlags(op1, op2, result) {
+    local zf:1 = (result == 0);
+    local sf:1 = (result s>= 0);
+    local cf:1 = carry(op1, op2);
+    local of:1 = scarry(op1, op2);
+    W = (W & 0x10) | (of << 3) | (zf << 2) | (cf << 1) | sf;
+}
+
+macro setSubFlags(op1, op2, result) {
+    local zf:1 = (result == 0);
+    local sf:1 = (result s>= 0);
+    local cf:1 = (op1 >= op2);
+    local of:1 = sborrow(op1, op2);
+    W = (W & 0x10) | (of << 3) | (zf << 2) | (cf << 1) | sf;
+}
+
+# ============================================================================
+# Constructors
+# ============================================================================
+
+# Branch target calculation
+# Target = opcode_addr + 1 + signed_displacement
+# F3850 Datasheet Table 3: "PC0 = (PC0) + H'ii' + 1"
+# F8 Guide Appendix D: "PC0 = ((PC0)+1) + H'aa'"
+# Mostek Data Book: "displacement added to addr+1"
+# inst_start = address of opcode byte, inst_next = inst_start + 2
+# So: target = inst_start + 1 + simm8 = inst_next - 1 + simm8
+reladdr: dest is simm8 [ dest = inst_next - 1 + simm8; ] { export *:2 dest; }
+
+# ============================================================================
+# Simple Data Movement Instructions
+# ============================================================================
+
+# CLR - Clear Accumulator (0x70) - same as LIS 0
+:CLR is op8=0x70 {
+    A = 0;
+}
+
+# LIS i - Load Immediate Short (0x71-0x7F)
+:LIS imm4 is op4hi=0x7 & imm4 & op4lo!=0 {
+    A = imm4;
+}
+
+# LI ii - Load Immediate (0x20)
+:LI imm8 is op8=0x20; imm8 {
+    A = imm8;
+}
+
+# NOP (0x2B)
+:NOP is op8=0x2B {
+}
+
+# ============================================================================
+# Scratchpad Register Instructions (LR A,r and LR r,A)
+# ============================================================================
+
+# LR A,r (0x40-0x4B) - direct registers r=0-11
+:LR acc, r4 is op4hi=0x4 & r4 & op4lo<0xC & acc {
+    A = r4;
+}
+
+# LR A,S (0x4C) - via IS
+:LR acc, iS is op8=0x4C & acc & iS {
+    local idx:1 = IS & 0x3F;
+    local ptr:1 = 0x40 + idx;
+    A = *[register]:1 ptr;
+}
+
+# LR A,I (0x4D) - via IS then IS++
+:LR acc, iI is op8=0x4D & acc & iI {
+    local idx:1 = IS & 0x3F;
+    local ptr:1 = 0x40 + idx;
+    A = *[register]:1 ptr;
+    IS = (IS & 0x38) | ((IS + 1) & 0x07);
+}
+
+# LR A,D (0x4E) - via IS then IS--
+:LR acc, iD is op8=0x4E & acc & iD {
+    local idx:1 = IS & 0x3F;
+    local ptr:1 = 0x40 + idx;
+    A = *[register]:1 ptr;
+    IS = (IS & 0x38) | ((IS - 1) & 0x07);
+}
+
+# LR A,15 (0x4F) - r=F: undocumented operation
+# Reference Card: "Illegal operation". Treated as NOP.
+:LR acc, r15 is op8=0x4F & acc & r15 {
+}
+
+# LR r,A (0x50-0x5B) - direct registers r=0-11
+:LR r4, acc is op4hi=0x5 & r4 & op4lo<0xC & acc {
+    r4 = A;
+}
+
+# LR S,A (0x5C) - via IS
+:LR iS, acc is op8=0x5C & iS & acc {
+    local idx:1 = IS & 0x3F;
+    local ptr:1 = 0x40 + idx;
+    *[register]:1 ptr = A;
+}
+
+# LR I,A (0x5D) - via IS then IS++
+:LR iI, acc is op8=0x5D & iI & acc {
+    local idx:1 = IS & 0x3F;
+    local ptr:1 = 0x40 + idx;
+    *[register]:1 ptr = A;
+    IS = (IS & 0x38) | ((IS + 1) & 0x07);
+}
+
+# LR D,A (0x5E) - via IS then IS--
+:LR iD, acc is op8=0x5E & iD & acc {
+    local idx:1 = IS & 0x3F;
+    local ptr:1 = 0x40 + idx;
+    *[register]:1 ptr = A;
+    IS = (IS & 0x38) | ((IS - 1) & 0x07);
+}
+
+# LR 15,A (0x5F) - undefined
+:LR r15, acc is op8=0x5F & r15 & acc {
+}
+
+# ============================================================================
+# Special Register Transfer Instructions
+# ============================================================================
+
+# LR A,KU (0x00) - A <- r12
+:LR acc, sKU is op8=0x00 & acc & sKU {
+    A = R12;
+}
+
+# LR A,KL (0x01) - A <- r13
+:LR acc, sKL is op8=0x01 & acc & sKL {
+    A = R13;
+}
+
+# LR A,QU (0x02) - A <- r14
+:LR acc, sQU is op8=0x02 & acc & sQU {
+    A = R14;
+}
+
+# LR A,QL (0x03) - A <- r15
+:LR acc, sQL is op8=0x03 & acc & sQL {
+    A = R15;
+}
+
+# LR KU,A (0x04) - r12 <- A
+:LR sKU, acc is op8=0x04 & sKU & acc {
+    R12 = A;
+}
+
+# LR KL,A (0x05) - r13 <- A
+:LR sKL, acc is op8=0x05 & sKL & acc {
+    R13 = A;
+}
+
+# LR QU,A (0x06) - r14 <- A
+:LR sQU, acc is op8=0x06 & sQU & acc {
+    R14 = A;
+}
+
+# LR QL,A (0x07) - r15 <- A
+:LR sQL, acc is op8=0x07 & sQL & acc {
+    R15 = A;
+}
+
+# LR K,P (0x08)
+:LR sK, sP is op8=0x08 & sK & sP {
+    K = PC1;
+}
+
+# LR P,K (0x09)
+:LR sP, sK is op8=0x09 & sP & sK {
+    PC1 = K;
+}
+
+# LR A,IS (0x0A)
+:LR acc, sIS is op8=0x0A & acc & sIS {
+    A = IS;
+}
+
+# LR IS,A (0x0B)
+:LR sIS, acc is op8=0x0B & sIS & acc {
+    IS = A & 0x3F;
+}
+
+# PK - PC loaded from K, return address saved in P (0x0C)
+:PK is op8=0x0C {
+    PC1 = inst_next;
+    local target:2 = K;
+    call [target];
+}
+
+# LR P0,Q - Jump via Q (0x0D)
+:LR sP0, sQ is op8=0x0D & sP0 & sQ {
+    local target:2 = Q;
+    goto [target];
+}
+
+# LR Q,DC (0x0E)
+:LR sQ, sDC is op8=0x0E & sQ & sDC {
+    Q = DC0;
+}
+
+# LR DC,Q (0x0F)
+:LR sDC, sQ is op8=0x0F & sDC & sQ {
+    DC0 = Q;
+}
+
+# LR DC,H (0x10)
+:LR sDC, sH is op8=0x10 & sDC & sH {
+    DC0 = H;
+}
+
+# LR H,DC (0x11)
+:LR sH, sDC is op8=0x11 & sH & sDC {
+    H = DC0;
+}
+
+# ============================================================================
+# Shift Instructions
+# ============================================================================
+
+# SR 1 - Shift Right 1 (0x12)
+# Flags: O=0, Z=I/O, C=0, S=1 (always positive after right shift with zero fill)
+:SR sh1 is op8=0x12 & sh1 {
+    A = A >> 1;
+    clearOC();
+    setZS(A);
+}
+
+# SL 1 - Shift Left 1 (0x13)
+# Flags: O=0, Z=I/O, C=0, S=I/O
+:SL sh1 is op8=0x13 & sh1 {
+    A = A << 1;
+    clearOC();
+    setZS(A);
+}
+
+# SR 4 - Shift Right 4 (0x14)
+:SR sh4 is op8=0x14 & sh4 {
+    A = A >> 4;
+    W = W & 0xF5;
+    local zf:1 = (A == 0);
+    local sf:1 = (A s>= 0);
+    W = (W & 0xF2) | (zf << 2) | sf;
+}
+
+# SL 4 - Shift Left 4 (0x15)

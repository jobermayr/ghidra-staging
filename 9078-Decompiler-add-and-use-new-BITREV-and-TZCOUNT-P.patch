+package ghidra.pcode.opbehavior;
+
+import java.math.BigInteger;
+
+import ghidra.program.model.pcode.PcodeOp;
+
+public class OpBehaviorTzcount extends UnaryOpBehavior {
+
+	public OpBehaviorTzcount() {
+		super(PcodeOp.TZCOUNT);
+	}
+
+	@Override
+	public long evaluateUnary(int sizeout, int sizein, long val) {
+		long mask = 1L;
+		long count = 0;
+		int totalbits = sizein * 8;
+		while (count < totalbits) {
+			if ((mask & val) != 0) {
+				break;
+			}
+			++count;
+			mask <<= 1;
+		}
+
+		return count;
+	}
+
+	@Override
+	public BigInteger evaluateUnary(int sizeout, int sizein, BigInteger unsignedIn1) {
+		int bitcount = 0;
+		int totalbits = sizein * 8;
+		while (bitcount < totalbits) {
+			if (unsignedIn1.testBit(bitcount)) {
+				break;
+			}
+			bitcount += 1;
+		}
+		if (sizeout == 1) {
+			bitcount &= 0xff;
+		}
+		else if (sizeout == 2) {
+			bitcount &= 0xffff;
+		}
+		return BigInteger.valueOf(bitcount);
+	}
+}

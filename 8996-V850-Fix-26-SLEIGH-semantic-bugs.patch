 # SATSUB reg1, reg2 - rrrrr000101RRRRR
-:satsub R0004, R1115 is op0510=0x05 & R0004 & R1115 & op1115!=0 
+:satsub R0004, R1115 is op0510=0x05 & R0004 & R1115 & op1115!=0
 {

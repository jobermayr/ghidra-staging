From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Liam <byteslice@airmail.cc>
Date: Fri, 27 Mar 2026 23:30:04 -0400
Subject: [PATCH] 9077: AArch64: add acquire load ordering to RCpc family
 instructions

---
 .../AARCH64/data/languages/AARCH64base.sinc     | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/Ghidra/Processors/AARCH64/data/languages/AARCH64base.sinc b/Ghidra/Processors/AARCH64/data/languages/AARCH64base.sinc
index c66884b369..041ea4bcec 100644
--- a/Ghidra/Processors/AARCH64/data/languages/AARCH64base.sinc
+++ b/Ghidra/Processors/AARCH64/data/languages/AARCH64base.sinc
@@ -2709,6 +2709,8 @@ is b_3031=0b11 & b_2429=0b111000 & b_21=1 & b_1515=0 & b_1011=0b00 & ls_opc8 & l
 :ldapr aa_Wt, [Rn_GPR64xsp]
 is b_3031=0b10 & b_2129=0b111000101 & b_1015=0b110000 & Rn_GPR64xsp & aa_Wt & ls_data4
 {
+	LOAcquire(Rn_GPR64xsp, 4:8);
+	build ls_data4;
 	aa_Wt = tmp_ldWn;
 }
 
@@ -2722,6 +2724,8 @@ is b_3031=0b10 & b_2129=0b111000101 & b_1015=0b110000 & Rn_GPR64xsp & aa_Wt & ls
 :ldapr aa_Xt, [Rn_GPR64xsp]
 is b_3031=0b11 & b_2129=0b111000101 & b_1015=0b110000 & Rn_GPR64xsp & aa_Xt & ls_data8
 {
+	LOAcquire(Rn_GPR64xsp, 8:8);
+	build ls_data8;
 	aa_Xt = tmp_ldXn;
 }
 
@@ -2734,6 +2738,8 @@ is b_3031=0b11 & b_2129=0b111000101 & b_1015=0b110000 & Rn_GPR64xsp & aa_Xt & ls
 :ldaprb aa_Wt, [Rn_GPR64xsp]
 is b_3031=0b00 & b_2129=0b111000101 & b_1015=0b110000 & Rn_GPR64xsp & aa_Wt & ls_data1
 {
+	LOAcquire(Rn_GPR64xsp, 1:8);
+	build ls_data1;
 	aa_Wt = tmp_ldWn;
 }
 
@@ -2745,6 +2751,8 @@ is b_3031=0b00 & b_2129=0b111000101 & b_1015=0b110000 & Rn_GPR64xsp & aa_Wt & ls
 :ldaprh aa_Wt, [Rn_GPR64xsp]
 is b_3031=0b01 & b_2129=0b111000101 & b_1015=0b110000 & Rn_GPR64xsp & aa_Wt & ls_data2
 {
+	LOAcquire(Rn_GPR64xsp, 2:8);
+	build ls_data2;
 	aa_Wt = tmp_ldWn;
 }
 
@@ -2759,6 +2767,7 @@ is b_3031=0b01 & b_2129=0b111000101 & b_1015=0b110000 & Rn_GPR64xsp & aa_Wt & ls
 :ldapur aa_Wt, addr_SIMM9
 is b_3031=0b10 & b_2129=0b011001010 & b_1011=0b00 & addr_SIMM9 & aa_Wt & aa_Xt
 {
+	LOAcquire(addr_SIMM9, 4:8);
 	aa_Xt = zext(*:4 addr_SIMM9);
 }
 
@@ -2768,6 +2777,7 @@ is b_3031=0b10 & b_2129=0b011001010 & b_1011=0b00 & addr_SIMM9 & aa_Wt & aa_Xt
 :ldapur aa_Xt, addr_SIMM9
 is b_3031=0b11 & b_2129=0b011001010 & b_1011=0b00 & addr_SIMM9 & aa_Xt
 {
+	LOAcquire(addr_SIMM9, 8:8);
 	aa_Xt = *addr_SIMM9;
 }
 
@@ -2778,6 +2788,7 @@ is b_3031=0b11 & b_2129=0b011001010 & b_1011=0b00 & addr_SIMM9 & aa_Xt
 :ldapurb aa_Wt, addr_SIMM9
 is b_3031=0b00 & b_2129=0b011001010 & b_1011=0b00 & addr_SIMM9 & aa_Wt & aa_Xt
 {
+	LOAcquire(addr_SIMM9, 1:8);
 	aa_Xt = zext(*:1 addr_SIMM9);
 }
 
@@ -2788,6 +2799,7 @@ is b_3031=0b00 & b_2129=0b011001010 & b_1011=0b00 & addr_SIMM9 & aa_Wt & aa_Xt
 :ldapurh aa_Wt, addr_SIMM9
 is b_3031=0b01 & b_2129=0b011001010 & b_1011=0b00 & addr_SIMM9 & aa_Wt & aa_Xt
 {
+	LOAcquire(addr_SIMM9, 2:8);
 	aa_Xt = zext(*:2 addr_SIMM9);
 }
 
@@ -2799,6 +2811,7 @@ is b_3031=0b01 & b_2129=0b011001010 & b_1011=0b00 & addr_SIMM9 & aa_Wt & aa_Xt
 :ldapursb aa_Wt, addr_SIMM9
 is b_3031=0b00 & b_2329=0b0110011 & b_22=1 & b_2121=0b0 & b_1011=0b00 & addr_SIMM9 & aa_Wt & aa_Xt
 {
+	LOAcquire(addr_SIMM9, 1:8);
 	aa_Xt = 0;
 	aa_Wt = sext(*:1 addr_SIMM9);
 }
@@ -2809,6 +2822,7 @@ is b_3031=0b00 & b_2329=0b0110011 & b_22=1 & b_2121=0b0 & b_1011=0b00 & addr_SIM
 :ldapursb aa_Xt, addr_SIMM9
 is b_3031=0b00 & b_2329=0b0110011 & b_22=0 & b_2121=0b0 & b_1011=0b00 & addr_SIMM9 & aa_Xt
 {
+	LOAcquire(addr_SIMM9, 1:8);
 	aa_Xt = sext(*:1 addr_SIMM9);
 }
 
@@ -2819,6 +2833,7 @@ is b_3031=0b00 & b_2329=0b0110011 & b_22=0 & b_2121=0b0 & b_1011=0b00 & addr_SIM
 :ldapursh aa_Wt, addr_SIMM9
 is b_3031=0b01 & b_2329=0b0110011 & b_22=1 & b_2121=0b0 & b_1011=0b00 & addr_SIMM9 & aa_Wt & aa_Xt
 {
+	LOAcquire(addr_SIMM9, 2:8);
 	aa_Xt = 0;
 	aa_Wt = sext(*:2 addr_SIMM9);
 }
@@ -2829,6 +2844,7 @@ is b_3031=0b01 & b_2329=0b0110011 & b_22=1 & b_2121=0b0 & b_1011=0b00 & addr_SIM
 :ldapursh aa_Xt, addr_SIMM9
 is b_3031=0b01 & b_2329=0b0110011 & b_22=0 & b_2121=0b0 & b_1011=0b00 & addr_SIMM9 & aa_Xt
 {
+	LOAcquire(addr_SIMM9, 2:8);
 	aa_Xt = sext(*:2 addr_SIMM9);
 }
 
@@ -2839,6 +2855,7 @@ is b_3031=0b01 & b_2329=0b0110011 & b_22=0 & b_2121=0b0 & b_1011=0b00 & addr_SIM
 :ldapursw aa_Xt, addr_SIMM9
 is b_3031=0b10 & b_2129=0b011001100 & b_1011=0b00 & addr_SIMM9 & aa_Xt
 {
+	LOAcquire(addr_SIMM9, 4:8);
 	aa_Xt = sext(*:4 addr_SIMM9);
 }
 
-- 

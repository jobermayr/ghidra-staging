From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Chase <chaseharland@bellsouth.net>
Date: Sat, 2 May 2026 00:55:52 -0400
Subject: [PATCH] 9149: fix: Decompiler: Enum values will use their complement
 representation if simpler expression

Addresses issues #7234 and #5021

Decompiler: Enum values will prefer their complement representation if it is a simpler experession.
---
 .../Features/Decompiler/src/decompile/cpp/type.cc | 15 ++++++++++++++-
 1 file changed, 14 insertions(+), 1 deletion(-)

diff --git a/Ghidra/Features/Decompiler/src/decompile/cpp/type.cc b/Ghidra/Features/Decompiler/src/decompile/cpp/type.cc
index 1046fb8bfd..1e610113fd 100644
--- a/Ghidra/Features/Decompiler/src/decompile/cpp/type.cc
+++ b/Ghidra/Features/Decompiler/src/decompile/cpp/type.cc
@@ -1552,6 +1552,18 @@ void TypeEnum::getMatches(uintb val,Representation &rep) const
 {
   map<uintb,string>::const_iterator iter;
   int4 count;
+  bool isComplement = false;
+
+  // First match complement if representation would be cleaner (combination of fewer enums)
+  // We'll do this by counting the number of set bits using Brian Kernighan's Algorithm
+  uintb bitsleft = val;
+  for (count=0;bitsleft!=0;++count){
+    bitsleft &= (bitsleft - 1);
+  }
+  if (count > size * 4) {
+    val = val ^ calc_mask(size);	// Switch value we are trying to represent (to complement)
+    isComplement = true;
+  }
 
   for(count=0;count<2;++count) {
     bool allmatch = true;
@@ -1589,10 +1601,11 @@ void TypeEnum::getMatches(uintb val,Representation &rep) const
       allmatch = (bitsleft == 0);
     }
     if (allmatch) {			// If we have a complete representation
-      rep.complement = (count==1);	// Set whether we represented original value or complement
+      rep.complement = isComplement;
       return;
     }
     val = val ^ calc_mask(size);	// Switch value we are trying to represent (to complement)
+    isComplement = !isComplement;
     rep.matchname.clear();		// Clear out old attempt
   }
   // If we reach here, no representation was possible, -matchname- is empty
-- 
2.45.1


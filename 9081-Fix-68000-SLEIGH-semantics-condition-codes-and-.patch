From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Sami Saari <polartape@users.noreply.github.com>
Date: Sat, 28 Mar 2026 13:15:27 +0000
Subject: [PATCH] 9081: Fix 68000 SLEIGH semantics: condition codes and operand
 handling

Fix 9 pcode semantics bugs in the 68000 processor definition that affect
all variants (68020, 68030, 68040, Coldfire). All fixes verified against
the CPU32 Reference Manual (Rev 1, Dec 1990) and M68000 Family
Programmer's Reference Manual.

Fixes:
- CMP/CMPA/CMPI/CMPM: X flag must not be affected (new cmpflags macro)
- ADDX: X flag was never set (add XF=CF after computation)
- NEGX: carry flag used signed comparison instead of unsigned
- CHK: double-dereference of EA value removed
- CHK2/CMP2: new e2ptr subtable to get EA address for bounds pair
- DIVS.W/DIVU.W: add overflow detection, skip register write on overflow
- DIVS.L signed 64/32: fix dividend assembly (zext for lower half)
- DIVS.L/DIVU.L: add VF=0
- MULS.L/MULU.L 32-to-32: add overflow detection via 64-bit multiply
- LSL/LSR register: V flag must always be cleared (was computed like ASL)

Related: #3818 (ADDX carry), #2856 (CHK pcode)
Tested: m68000 pcode emulator tests pass (17/17 O0, 17/17 O3)
---
 .../68000/data/languages/68000.sinc           | 119 ++++++++++--------
 1 file changed, 69 insertions(+), 50 deletions(-)

diff --git a/Ghidra/Processors/68000/data/languages/68000.sinc b/Ghidra/Processors/68000/data/languages/68000.sinc
index 89eb2d74a4..80de4474c2 100644
--- a/Ghidra/Processors/68000/data/languages/68000.sinc
+++ b/Ghidra/Processors/68000/data/languages/68000.sinc
@@ -608,6 +608,17 @@ eaptr: (extw)			is mode=7 & regan=3; extw				[ pcmode=1; ] { export extw; }
 eaptr: (d16)".w"		is mode=7 & regan=0; d16				{ export *[const]:4 d16; }
 eaptr: (d32)".l"		is mode=7 & regan=1; d32				{ export *[const]:4 d32; }
 
+# Like eaptr but uses saved context (savmod2/regsan) for second EA position.
+# Used by CHK2/CMP2 which need the EA address (not value) but have an
+# extension word between the opword and EA extensions.
+e2ptr: (regsan)			is savmod2=2 & regsan					{ export regsan; }
+e2ptr: (d16,regsan)		is savmod2=5 & regsan; d16				{ local tmp = regsan+d16; export tmp; }
+e2ptr: (extw)			is savmod2=6; extw					[ pcmode=0; eanum=1; ] { build extw; export extw; }
+e2ptr: (d16,PC)			is PC & savmod2=7 & regsan=2; d16			{ tmp:4 = inst_start+2+d16; export tmp; }
+e2ptr: (extw)			is savmod2=7 & regsan=3; extw				[ pcmode=1; ] { build extw; export extw; }
+e2ptr: (d16)".w"		is savmod2=7 & regsan=0; d16				{ export *[const]:4 d16; }
+e2ptr: (d32)".l"		is savmod2=7 & regsan=1; d32				{ export *[const]:4 d32; }
+
 # Data register or predecrement addressing
 Ty: -(regan)	is rmbit=1 & regan		{ regan = regan-4; export *:4 regan; }
 Ty: regdn	is rmbit=0 & regdn		{ export regdn; }
@@ -758,6 +769,12 @@ macro subflags(op1,op2) {
  XF = CF;
 }
 
+# Like subflags but does not affect XF — for CMP/CMPA/CMPI/CMPM
+macro cmpflags(op1,op2) {
+ CF = op1 < op2;
+ VF = sborrow(op1,op2);
+}
+
 macro sub(op1,op2res) {
 	local var1 = op1;
 	local var2 = op2res;
@@ -776,7 +793,7 @@ macro subxflags(op1,op2) {
 }
 
 macro negxsubflags(op1) {
- CF = 0 s< op1;
+ CF = (op1 != 0);
  VF = sborrow(0,op1);
  XF = CF;
 }
@@ -868,11 +885,9 @@ macro arithmeticShiftRight(count, register, width) {
 macro logicalShiftLeft(count, register, width) {
 	local modcount = count & 63;
 	local lbit:1 = ((register >> (width - modcount) & 1) != 0);
-	local msbBefore:4 = zext(register s< 0);
 	register = register << modcount;
 	resflags(register);
-	local msbAfter:4 = zext(register s< 0);
-	VF = (msbBefore ^ msbAfter) != 0;
+	VF = 0;
 	CF = (modcount != 0) * lbit;
 	XF = ((modcount == 0) * XF) + ((modcount != 0) * CF);
 }
@@ -880,11 +895,9 @@ macro logicalShiftLeft(count, register, width) {
 macro logicalShiftRight(count, register, width) {
 	local modcount = count & 63;
 	local lbit:1 = ((register >> (modcount-1) & 1) != 0);
-	local msbBefore:4 = zext(register s< 0);
 	register = register >> modcount;
 	resflags(register);
-	local msbAfter:4 = zext(register s< 0);
-	VF = (msbBefore ^ msbAfter) != 0;
+	VF = 0;
 	CF = (modcount != 0) * lbit;
 	XF = ((modcount == 0) * XF) + ((modcount != 0) * CF);
 }
@@ -972,11 +985,11 @@ with : extGUARD=1 {
 
 

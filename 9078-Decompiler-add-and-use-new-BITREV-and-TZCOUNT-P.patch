+package ghidra.pcode.opbehavior;
+
+import ghidra.program.model.pcode.PcodeOp;
+
+import java.math.BigInteger;
+
+public class OpBehaviorBitrev extends UnaryOpBehavior {
+
+	public OpBehaviorBitrev() {
+		super(PcodeOp.BITREV);
+	}
+
+	@Override
+	public long evaluateUnary(int sizeout, int sizein, long in1) {
+		long res = 0;
+		for (int i = 0; i < sizein * 8; i++) {
+			res <<= 1;
+			res |= (in1 & 1);
+			in1 >>= 1;
+		}
+		return res;
+	}
+
+	@Override
+	public BigInteger evaluateUnary(int sizeout, int sizein, BigInteger in1) {
+		byte[] resbytes = new byte[sizein];
+		for (int i = 0; i < sizein * 8; i++) {
+			if (in1.testBit(i)) {
+				resbytes[i / 8] |= (byte) (1 << (7 - (i % 8)));
+			}
+		}
+		return new BigInteger(1, resbytes);
+	}
+}

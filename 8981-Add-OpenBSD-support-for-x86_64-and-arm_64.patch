 	[name: "mac_arm_64", os: "osx", arch: "arm64"],
 	[name: "freebsd_x86_64", os: "freebsd", arch: "x86_64"],
-	[name: "freebsd_arm_64", os: "freebsd", arch: "arm64"]
+	[name: "freebsd_arm_64", os: "freebsd", arch: "arm64"],
+	[name: "openbsd_x86_64", os: "openbsd", arch: "x86_64"],

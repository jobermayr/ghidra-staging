 # evfsnmsub
 # Vector Floating-Point Single-Precision Negative Multiply-Substract
 :evfsnmsub D,A,B is OP=4 & D & A & B & XOP_0_10=0x28B
 {
-	local tmpAL:4 = A:4; local tmpAH:4 = A(4);

-	__saturate(R1115);
+	if (!$(OV)) goto <no_sat>;
+	if (R1115 s< 0) goto <neg_sat>;
+	result = 0x7FFFFFFF;
+	goto <no_sat>;
+	<neg_sat>
+	result = 0x80000000;
+	<no_sat>
+	R1115 = result;
+	set_S(result);
+	set_Z(result);
 }
 
 #SATADD imm5, reg2 - rrrrr010001iiiii
 :satadd s0004, R1115 is op0510=0x11 & s0004 & R1115 & op1115!=0
 {
-	set_general_flags_pos(R1115, s0004);
+	set_CY_pos(R1115, s0004);
+	set_OV_pos(R1115, s0004);
+	local result:4 = R1115 + s0004;
 	$(SAT) = $(SAT) || $(OV);
-	R1115 = R1115 + s0004;
-	__saturate(R1115);
